    "url": "https://github.com/lucasmclaughlin/hedgeFun/issues"
  },
  "homepage": "https://github.com/lucasmclaughlin/hedgeFun#readme",
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  }
}
