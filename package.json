{
  "name": "hedgefun",
  "version": "1.0.0",
  "description": "A 2D side-scrolling simulation game about growing and managing a hedgerow ecosystem. Plant native UK hedge species, watch them grow through the seasons, and attract wildlife — from underground moles to treetop birds.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts",
    "artool": "vite tools/artool"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasmclaughlin/hedgeFun.git"
  },
  "keywords": [],
